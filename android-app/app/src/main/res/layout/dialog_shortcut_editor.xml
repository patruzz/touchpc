<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/shortcut_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/shortcut_name_hint"
            android:inputType="text"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/record_keys"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <TextView
            android:id="@+id/recorded_keys_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="@string/tap_to_record"
            android:textAlignment="center"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:minHeight="56dp"
            android:gravity="center" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Modifier checkboxes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/mod_ctrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ctrl" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/mod_shift"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shift" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/mod_alt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alt" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/mod_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meta" />

    </LinearLayout>

</LinearLayout>
